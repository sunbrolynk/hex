# HEx example configuration
# -----------------------------------------------------------------------------
# Every secret field below is INTENTIONALLY EMPTY and carries the exact command
# to generate a strong value. There are NO usable defaults. HEx refuses to start
# if a required secret is missing, empty, low-entropy, or a known placeholder.
# Copy this file to `.env`, fill each secret with a freshly generated value, and
# NEVER commit your `.env`. See docs/SECRETS.md and docs/decisions/0005.
# -----------------------------------------------------------------------------


# === Core application secrets (REQUIRED) =====================================

# Application signing key (sessions/CSRF/token signing). REQUIRED.
# App refuses to start if unset or low-entropy.
# Generate (64-byte URL-safe, CSPRNG):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
HEX_SECRET_KEY=

# Key-encryption key (KEK) for the secrets broker that envelope-encrypts provider
# credentials at rest. REQUIRED.
# Generate (32 random bytes, base64):
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# IMPORTANT: source this from OUTSIDE the database (KMS / Vault / secrets manager / injected
# env / secret mount). Do not store it next to the encrypted data it protects.
HEX_KEK=

# Audit-log integrity key. HMAC-SHA256 keys the tamper-evident hash chain over the
# append-only audit log. REQUIRED. App refuses to start if unset or low-entropy.
# This is an INTEGRITY key, not an encryption key: rotating it makes pre-rotation
# entries no longer verify (by design). Store it durably.
# Generate (48-byte URL-safe, CSPRNG):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
HEX_AUDIT_KEY=


# === Database (REQUIRED) =====================================================

# Postgres password. REQUIRED.
# Generate (32-byte URL-safe):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
HEX_DB_PASSWORD=

HEX_DB_HOST=localhost
HEX_DB_PORT=5432
HEX_DB_NAME=hex
HEX_DB_USER=hex


# === Authentik mode ==========================================================
# How Authentik is provided (ADR 0013). NOT a secret — a real default is correct.
#   bundled  (default) = HEx rolls up its own Authentik stack (server, worker,
#              Postgres, Redis). The "Bundled Authentik stack" secrets below apply.
#              HEx's compose enables the `bundled-authentik` profile (it sets
#              COMPOSE_PROFILES=bundled-authentik) so those services start.
#   external = you already run Authentik; HEx points at it and starts no Authentik
#              services. The connection vars just below are required; the bundled
#              stack secrets are NOT.
HEX_AUTHENTIK_MODE=bundled


# === Authentik (identity source of truth) ====================================
# Required in EXTERNAL mode (and used in BUNDLED mode after bootstrap wires them).
# HEx authenticates users via Authentik (OIDC) and provisions identity via the
# Authentik API using a DEDICATED, LEAST-PRIVILEGE service-account token.
# Do NOT use an Authentik admin token here. Create a service account scoped to
# only the user/group/enrollment operations HEx needs. See docs/SECURITY_MODEL.

AUTHENTIK_BASE_URL=

# OIDC client credentials for HEx's own login (relying party).
AUTHENTIK_OIDC_CLIENT_ID=
# OIDC client secret. REQUIRED if your provider type uses one.
# Generate in Authentik when creating the OIDC provider; paste it here.
AUTHENTIK_OIDC_CLIENT_SECRET=

# Scoped service-account API token for provisioning (NOT an admin token).
# After first-run bootstrap, HEx rotates to its own scoped service-account token and uses
# it here. During first run this may be left blank; bootstrap wires it. See docs/BOOTSTRAP.
AUTHENTIK_API_TOKEN=


# === HEx OIDC relying-party login (HEX_-prefixed; read by HEx itself) ================
# How HEx logs its own users in via Authentik (Authorization-Code BFF). OPTIONAL until
# first-run bootstrap creates the OIDC app (Slice 3); until set, the login surface reports
# "not configured" rather than refusing to boot. The values mirror the confidential OIDC
# application Authentik provisions for HEx.
# NOTE (split-horizon): HEX_AUTHENTIK_BASE_URL must be reachable BOTH by the browser (for the
# authorize redirect + token issuer) and by the HEx container (for token/JWKS). See docs/DEPLOYMENT.
HEX_AUTHENTIK_BASE_URL=
HEX_AUTHENTIK_OIDC_CLIENT_ID=
# Generated by Authentik when the OIDC provider is created.
HEX_AUTHENTIK_OIDC_CLIENT_SECRET=
# Authentik application slug; the OIDC discovery doc lives at
# <base>/application/o/<slug>/.well-known/openid-configuration
HEX_AUTHENTIK_OIDC_APP_SLUG=hex


# === Bundled Authentik stack (BUNDLED MODE ONLY) =============================
# Required only when HEX_AUTHENTIK_MODE=bundled; ignored in external mode.
# HEx bundles and orchestrates Authentik (server + worker + its own Postgres + Redis).
# These seed Authentik on its FIRST start only. See docs/DEPLOYMENT.md and docs/BOOTSTRAP.md.

# Authentik's own signing key. REQUIRED.
# Generate (60+ bytes):
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
AUTHENTIK_SECRET_KEY=

# Authentik PostgreSQL + Redis passwords (separate datastore from HEx's DB). REQUIRED.
# Generate each (32-byte URL-safe):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTHENTIK_PG_PASSWORD=
AUTHENTIK_REDIS_PASSWORD=

# Initial Authentik admin (akadmin) password — stored PRE-HASHED to avoid plaintext.
# Generate the hash (run against the bundled Authentik image):
#   docker compose run --rm authentik-server hash_password 'your-strong-passphrase'
# NOTE: paste the hash LITERALLY into deploy/.env (loaded via env_file). Do NOT escape
# '$' as '$$' — env_file passes the value through unchanged, and doubling '$' corrupts it.
AUTHENTIK_BOOTSTRAP_PASSWORD_HASH=

# First-start API token HEx uses to finish wiring Authentik, then ROTATES AWAY from.
# Read only on Authentik's first start. Generate (48-byte URL-safe):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTHENTIK_BOOTSTRAP_TOKEN=

# Email for the initial Authentik admin.
AUTHENTIK_BOOTSTRAP_EMAIL=


# === HEx first-run setup gate ================================================
# One-time token required to begin first-run owner setup. HEx prints this to its
# CONTAINER LOGS on first start; only someone with host/log access can claim ownership.
# Leave blank to have HEx generate-and-log it on first run (recommended). See docs/BOOTSTRAP.
HEX_SETUP_TOKEN=


# === Proxy / forward-auth trust (REQUIRED for header-trust safety) ===========
# HEx must NOT trust proxy-injected identity headers unless the request provably
# transited the proxy. Set a shared secret the proxy sends and HEx verifies on
# every request (in addition to OIDC token validation). See docs/SECURITY_MODEL §2.
# Generate (48-byte URL-safe):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
HEX_PROXY_SHARED_SECRET=


# === Runtime / security posture =============================================

# Public base URL of HEx (used to build invite links). REQUIRED.
HEX_PUBLIC_BASE_URL=

# Invite link TTL in hours (capability tokens are single-use, hard cap 1 accept).
HEX_INVITE_TTL_HOURS=72

# Argon2id parameters for any HEx-local credential hashing.
# Floor is OWASP minimum (m=19456 KiB, t=2, p=1). Tune UP for an identity service
# within your hardware's latency budget. See docs/SECURITY_MODEL §3.
HEX_ARGON2_MEMORY_KIB=65536
HEX_ARGON2_TIME_COST=3
HEX_ARGON2_PARALLELISM=1

# Set to "production" in production. Affects strictness of boot-time checks.
HEX_ENV=production


# === Break-glass owner access (DISABLED BY DEFAULT) ==========================
# Emergency local owner login for when Authentik/OIDC is UNREACHABLE and you need
# to get in to diagnose/repair. This is the ONE local credential that bypasses
# Authentik, so it is the highest-value single target. Leave disabled unless you
# understand the tradeoff. See docs/decisions/0008 and docs/SECURITY_MODEL §13.

# Master switch. "false" = no local login path exists at all (recommended default).
HEX_BREAKGLASS_ENABLED=false

# Only accept break-glass auth when Authentik/OIDC fails its health check.
# "true" keeps it closed whenever a healthy Authentik is reachable.
HEX_BREAKGLASS_REQUIRE_IDP_DOWN=true

# Restrict the break-glass path to local/LAN network (not internet-exposed).
HEX_BREAKGLASS_LOCAL_ONLY=true

# Break-glass owner username.
HEX_BREAKGLASS_USERNAME=

# Break-glass password — store the Argon2id HASH, never the plaintext.
# Generate a strong passphrase, then hash it (argon2-cffi), e.g.:
#   python -c "from argon2 import PasswordHasher; import getpass; \
#     print(PasswordHasher(memory_cost=65536, time_cost=3, parallelism=1)\
#     .hash(getpass.getpass('break-glass passphrase: ')))"
HEX_BREAKGLASS_PASSWORD_HASH=

# TOTP MFA secret for break-glass (STRONGLY recommended when enabled).
# Generate a base32 secret:
#   python -c "import pyotp; print(pyotp.random_base32())"
HEX_BREAKGLASS_TOTP_SECRET=

# Break-glass listener (only opened when ENABLED=true). It is a SEPARATE socket from the main app
# so the emergency path is unreachable through the reverse proxy. In the bundled Docker stack the
# container binds all interfaces (set in compose) and the LAN/loopback restriction is the host-side
# publish bind HEX_BREAKGLASS_HOST_BIND (compose). For a bare-metal run these are the bind targets;
# keep loopback unless you reach HEx over a VPN/LAN, then set your LAN IP.
HEX_BREAKGLASS_LISTEN_HOST=127.0.0.1
HEX_BREAKGLASS_LISTEN_PORT=8001
# Docker only: host interface + port the break-glass socket is published on (LAN/loopback ONLY).
HEX_BREAKGLASS_HOST_BIND=127.0.0.1
HEX_BREAKGLASS_HOST_PORT=52001


# === Per-provider credentials ================================================
# Each provider's credential is a LEAST-PRIVILEGE service account, stored
# envelope-encrypted at rest by the secrets broker (these env values are the
# initial source; rotate via config, not code). Add per provider as integrations
# land. Example shape (do not fill with admin keys):
#
# PROVIDER_JELLYFIN_BASE_URL=
# PROVIDER_JELLYFIN_API_KEY=        # scoped API key, generate in Jellyfin
# PROVIDER_PLEX_TOKEN=              # token for the share/invite account only
# PROVIDER_SEERR_BASE_URL=
# PROVIDER_SEERR_API_KEY=           # Seerr (Overseerr-compatible) API key
